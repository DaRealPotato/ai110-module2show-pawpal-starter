classDiagram
    class Owner {
        +str name
        +int available_minutes
        +add_task(task) None
        +get_schedule() Schedule
    }

    class Pet {
        +str name
        +str species
        +int age
    }

    class Task {
        +str title
        +int duration_minutes
        +str priority
        +bool is_recurring
        +fits_in(minutes_remaining) bool
    }

    class Availability {
        +int start_hour
        +int end_hour
        +get_total_minutes() int
    }

    class Schedule {
        +list entries
        +add_entry(task, start_time) None
        +display() str
    }

    class Scheduler {
        +generate(owner, tasks) Schedule
    }

    Owner "1" --> "1" Pet : owns
    Pet "1" --> "*" Task : has needs
    Owner "1" --> "1" Availability : has
    Scheduler --> Owner : takes
    Scheduler --> Schedule : produces
