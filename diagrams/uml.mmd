classDiagram
    class Owner {
        +str name
        +int available_minutes
        +Pet pet
        +get_schedule() Schedule
    }

    class Pet {
        +str name
        +str species
        +int age
        +list tasks
        +add_task(task) None
        +edit_task(title, updated_task) None
    }

    class Task {
        +str title
        +int duration_minutes
        +str priority
        +bool is_recurring
        +fits_in(minutes_remaining) bool
    }

    class ScheduleEntry {
        +Task task
        +int start_time
        +str reasoning
    }

    class Schedule {
        +list entries
        +add_entry(task, start_time, reasoning) None
        +display() str
    }

    class Scheduler {
        +generate(owner) Schedule
    }

    Owner "1" --> "1" Pet : owns
    Pet "1" --> "*" Task : has needs
    Owner --> Scheduler : calls via get_schedule
    Scheduler --> Schedule : produces
    Schedule "1" --> "*" ScheduleEntry : contains
